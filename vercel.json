{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "vercel-nodejs@20"
    }
  },
  "rewrites": [
    { "source": "/auth/discord", "destination": "/api/auth-discord.js" },
    { "source": "/auth/logout", "destination": "/api/auth-logout.js" },
    { "source": "/api/me", "destination": "/api/me.js" }
  ]
}
